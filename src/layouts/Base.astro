---
import '../styles/global.css';
const { title = 'Leonardo Mazzeo — Visual Designer', description = 'Portfolio di Leonardo Mazzeo, visual & editorial designer. Brand identity, editoria, comunicazione.' } = Astro.props;
const nav = [
  { href: '/', label: 'Lavori' },
  { href: '/about', label: 'About' },
];
---
<!doctype html>
<html lang="it">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <link rel="icon" href="/mascot.webp" />
  <!-- Iubenda Cookie Solution (banner + consenso) -->
  <script type="text/javascript" src="https://embeds.iubenda.com/widgets/287c2c8e-7764-43e4-9c2d-b68821b4a1a8.js" is:inline></script>
  <style>
    header.nav{position:fixed;top:0;left:0;right:0;z-index:50;display:flex;justify-content:space-between;
      align-items:center;padding:16px clamp(20px,5vw,56px);mix-blend-mode:difference;color:#fff}
    header.nav a{font-weight:700}
    header.nav .logo{font-weight:900;letter-spacing:-.02em;font-size:1.1rem}
    header.nav nav{display:flex;gap:22px}
    footer.foot{background:var(--blue);color:#fff;padding:clamp(48px,8vw,96px) 0}
    footer.foot .grid{align-items:end}
    footer.foot a{border-bottom:1px solid rgba(255,255,255,.4)}
    /* cookie banner */
    .cookie{position:fixed;left:16px;bottom:16px;z-index:60;max-width:360px;background:#fff;
      border:2px solid var(--ink);border-radius:14px;padding:16px 18px 16px 16px;display:none;
      box-shadow:0 12px 40px rgba(0,0,0,.18)}
    .cookie.show{display:flex;gap:12px;align-items:flex-start}
    .cookie img{width:56px;height:56px;object-fit:contain;flex:none}
    .cookie p{font-size:.82rem;line-height:1.45}
    .cookie .row{display:flex;gap:8px;margin-top:10px}
    .cookie button{font-weight:700;font-size:.78rem;padding:7px 12px;border-radius:100px;cursor:pointer;border:1.5px solid var(--ink)}
    .cookie .ok{background:var(--blue);color:#fff;border-color:var(--blue)}
    .cookie .no{background:#fff}
    .cookie a{color:var(--blue);border-bottom:1px solid var(--blue)}
    .cookie .prefs{margin-top:9px;font-size:.72rem;color:var(--muted);cursor:pointer;
      background:none;border:0;padding:0;text-decoration:underline}
    /* nascondo il banner di default di Iubenda: uso il mio */
    #iubenda-cs-banner{display:none!important}
  </style>
</head>
<body>
  <header class="nav">
    <a class="logo" href="/">Mazz</a>
    <nav>{nav.map(n => <a href={n.href}>{n.label}</a>)}</nav>
  </header>

  <main><slot /></main>

  <footer class="foot">
    <div class="wrap grid">
      <div style="grid-column:span 7">
        <p class="kicker" style="color:rgba(255,255,255,.7)">Lavoriamo insieme</p>
        <h2 style="margin-top:.3em">leonardo.mazzeo02<br/>@gmail.com</h2>
      </div>
      <div style="grid-column:span 5">
        <p><a href="https://instagram.com/mazzdesign_">Instagram</a> · <a href="https://www.linkedin.com/in/leonardo-mazzeo-0562ab295/">LinkedIn</a></p>
        <p style="margin-top:8px;font-size:.85rem">
          <a href="https://www.iubenda.com/privacy-policy/32595953" class="iubenda-white iubenda-noiframe iubenda-embed" title="Privacy Policy">Privacy Policy</a>
          ·
          <a href="https://www.iubenda.com/privacy-policy/32595953/cookie-policy" class="iubenda-white iubenda-noiframe iubenda-embed" title="Cookie Policy">Cookie Policy</a>
          · <a href="#" id="ck-open" style="cursor:pointer">Preferenze cookie</a>
        </p>
        <p style="margin-top:8px;opacity:.7;font-size:.85rem">© {new Date().getFullYear()} Leonardo Mazzeo · Visual Designer</p>
      </div>
    </div>
  </footer>

  <!-- Cookie banner personalizzato (mascotte) collegato al consenso Iubenda -->
  <aside class="cookie" id="cookie" role="dialog" aria-label="Cookie">
    <img src="/mascot.webp" alt="" />
    <div>
      <p><strong>Ciao! Uso i cookie</strong> per capire cosa piace e migliorare il sito. Dettagli nella
        <a href="https://www.iubenda.com/privacy-policy/32595953/cookie-policy" target="_blank" rel="noopener">Cookie Policy</a>
        e <a href="https://www.iubenda.com/privacy-policy/32595953" target="_blank" rel="noopener">Privacy Policy</a>.</p>
      <div class="row">
        <button class="ok" id="ck-accept">Accetta</button>
        <button class="no" id="ck-reject">Solo necessari</button>
      </div>
      <button class="prefs" id="ck-prefs">Personalizza le preferenze</button>
    </div>
  </aside>

  <!-- Iubenda: loader per i link Privacy/Cookie Policy nel footer -->
  <script type="text/javascript" is:inline>(function (w,d) {var loader = function () {var s = d.createElement("script"), tag = d.getElementsByTagName("script")[0]; s.src="https://cdn.iubenda.com/iubenda.js"; tag.parentNode.insertBefore(s,tag);}; if(w.addEventListener){w.addEventListener("load", loader, false);}else if(w.attachEvent){w.attachEvent("onload", loader);}else{w.onload = loader;}})(window, document);</script>

  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    gsap.registerPlugin(ScrollTrigger);

    // smooth scroll
    const lenis = new Lenis({ lerp: 0.09 });
    function raf(t){ lenis.raf(t); requestAnimationFrame(raf); }
    requestAnimationFrame(raf);
    lenis.on('scroll', ScrollTrigger.update);

    // reveal on scroll
    document.querySelectorAll('[data-reveal]').forEach((el, i) => {
      ScrollTrigger.create({
        trigger: el, start: 'top 85%',
        onEnter: () => el.classList.add('is-in')
      });
    });

    // Cookie: banner personalizzato collegato al consenso Iubenda
    const ck = document.getElementById('cookie');
    // Nascondo il banner di default di Iubenda (batte la sua CSS inline con !important)
    (function(){
      let n = 0;
      const iv = setInterval(() => {
        const b = document.getElementById('iubenda-cs-banner');
        if (b) b.style.setProperty('display', 'none', 'important');
        if (++n > 50) clearInterval(iv);
      }, 200);
    })();
    function iub(fn){
      const t = setInterval(() => {
        if (window._iub && _iub.cs && _iub.cs.api) { clearInterval(t); try { fn(_iub.cs.api); } catch(e){} }
      }, 150);
      setTimeout(() => clearInterval(t), 8000);
    }
    if (ck && !localStorage.getItem('ck-choice')) setTimeout(() => ck.classList.add('show'), 900);
    function ckChoose(accept){
      iub(api => { if (accept) { api.acceptAll && api.acceptAll(); } else { api.rejectAll && api.rejectAll(); } });
      localStorage.setItem('ck-choice', accept ? 'all' : 'necessary');
      ck && ck.classList.remove('show');
    }
    document.getElementById('ck-accept')?.addEventListener('click', () => ckChoose(true));
    document.getElementById('ck-reject')?.addEventListener('click', () => ckChoose(false));
    document.getElementById('ck-prefs')?.addEventListener('click', () => iub(api => api.openPreferences && api.openPreferences()));
    document.getElementById('ck-open')?.addEventListener('click', (e) => { e.preventDefault(); iub(api => api.openPreferences && api.openPreferences()); });
  </script>
</body>
</html>
