---
import { works } from '../data/works.js';
const { exclude = null, speed = 1.5 } = Astro.props; // px per frame
const items = works.filter(w => w.slug !== exclude);
const loop = [...items, ...items]; // duplico per il loop infinito
---
<div class="marquee" data-speed={speed}>
  <div class="marquee__track">
    {loop.map((w) => (
      <a class="m-item" href={`/work/${w.slug}`} draggable="false">
        {w.cover
          ? <img src={w.cover} alt={w.title} loading="eager" decoding="async" draggable="false" />
          : <span class="m-ph" style={`background:${w.accent}`}>{w.title}</span>}
        <span class="m-cap">{w.title} <i>· {w.category}</i></span>
      </a>
    ))}
  </div>
</div>

<style>
  .marquee{overflow-x:auto;overflow-y:hidden;padding:8px 0 4px;
    cursor:grab;scrollbar-width:none;-ms-overflow-style:none;-webkit-overflow-scrolling:touch}
  .marquee::-webkit-scrollbar{display:none}
  .marquee:active{cursor:grabbing}
  .marquee__track{display:flex;gap:26px;width:max-content;align-items:flex-start;padding:0 clamp(20px,5vw,56px)}
  .m-item{flex:none;display:flex;flex-direction:column;align-items:flex-start;gap:10px}
  .m-item img{max-width:none}
  .m-item img{height:clamp(240px,32vh,420px);width:auto;display:block;border-radius:10px;
    transition:transform .5s ease;user-select:none}
  .m-item:hover img{transform:translateY(-6px)}
  .m-ph{height:clamp(240px,32vh,420px);width:clamp(240px,22vw,320px);display:grid;place-items:center;
    color:#fff;font-weight:900;border-radius:10px;text-align:center;padding:0 12px}
  .m-cap{font-weight:700;font-size:.9rem;max-width:300px;line-height:1.3}
  .m-cap i{color:var(--muted);font-weight:500;font-style:normal}
</style>

<script>
  function initMarquee(el){
    const track = el.querySelector('.marquee__track');
    const speed = parseFloat(el.dataset.speed) || 1.5;
    let paused = false, touching = false, idle;
    const half = () => track.scrollWidth / 2;
    const resumeSoon = (ms) => { clearTimeout(idle); idle = setTimeout(() => { paused = false; }, ms); };

    el.addEventListener('pointerenter', () => { if (!touching) paused = true; });
    el.addEventListener('pointerleave', () => { if (!touching) paused = false; });
    el.addEventListener('touchstart', () => { touching = true; paused = true; }, { passive: true });
    el.addEventListener('touchend', () => { touching = false; resumeSoon(1600); }, { passive: true });
    el.addEventListener('wheel', () => { paused = true; resumeSoon(1200); }, { passive: true });

    function tick(){
      if (!paused) el.scrollLeft += speed;
      if (!touching) { const h = half(); if (h && el.scrollLeft >= h) el.scrollLeft -= h; }
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  document.querySelectorAll('.marquee').forEach(initMarquee);
</script>
