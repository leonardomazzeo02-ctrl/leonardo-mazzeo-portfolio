---
import Base from '../layouts/Base.astro';
import { works } from '../data/works.js';
const typeOf = (c) => c.split('·')[0].trim();
const types = [...new Set(works.map(w => typeOf(w.category)))];
const years = [...new Set(works.map(w => w.year))].sort().reverse();
---
<Base title="Lavori · Leonardo Mazzeo" description="Tutti i progetti di Leonardo Mazzeo: brand identity, editoria, manifesti, social.">
  <section class="wrap" style="padding-top:16vh">
    <p class="kicker" data-reveal>Portfolio</p>
    <h1 data-reveal style="margin-top:.15em">Lavori</h1>

    <div class="filters">
      <div class="fgroup">
        <span class="flabel">Tipo</span>
        <button class="fbtn is-active" data-f="type" data-v="all">Tutti</button>
        {types.map(t => <button class="fbtn" data-f="type" data-v={t}>{t}</button>)}
      </div>
      <div class="fgroup">
        <span class="flabel">Anno</span>
        <button class="fbtn is-active" data-f="year" data-v="all">Tutti</button>
        {years.map(y => <button class="fbtn" data-f="year" data-v={y}>{y}</button>)}
      </div>
    </div>

    <div class="works-grid" id="grid">
      {works.map(w => (
        <a href={`/work/${w.slug}`} class="card" data-type={typeOf(w.category)} data-year={w.year}>
          <div class="card__media" style={`--accent:${w.accent}`}>
            {w.cover ? <img src={w.cover} alt={w.title} loading="lazy" /> : <span class="card__ph">{w.title}</span>}
          </div>
          <div class="card__meta">
            <h3>{w.title} <span class="sub">· {w.subtitle}</span></h3>
            <span class="kicker">{w.category} · {w.year}</span>
          </div>
        </a>
      ))}
    </div>
    <p id="empty" class="body" style="display:none;margin-top:24px;color:var(--muted)">Nessun progetto con questi filtri.</p>
  </section>

  <style>
    .filters{display:flex;flex-wrap:wrap;gap:20px 34px;margin:26px 0 44px;
      border-top:2px solid var(--ink);padding-top:18px}
    .fgroup{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
    .flabel{font-weight:600;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-right:6px}
    .fbtn{font-family:var(--font);font-weight:600;font-size:.85rem;padding:6px 14px;border-radius:100px;
      border:1.5px solid var(--rule);background:transparent;color:var(--ink);cursor:pointer;transition:.2s}
    .fbtn:hover{border-color:var(--ink)}
    .fbtn.is-active{background:var(--ink);color:var(--paper);border-color:var(--ink)}
    .works-grid{columns:3;column-gap:clamp(20px,3vw,40px)}
    .card{display:inline-block;width:100%;margin:0 0 clamp(24px,3.5vw,44px);break-inside:avoid}
    .card__media{border-radius:10px;overflow:hidden;background:var(--accent);line-height:0}
    .card__media img{width:100%;height:auto;display:block;transition:transform .6s cubic-bezier(.2,.8,.2,1)}
    .card:hover .card__media{box-shadow:0 14px 40px rgba(20,20,20,.14)}
    .card:hover .card__media img{transform:scale(1.02)}
    .card__ph{display:grid;place-items:center;aspect-ratio:4/3;color:#fff;font-weight:900;font-size:1.6rem;padding:0 12px;text-align:center}
    .card__meta{display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin-top:12px;
      border-top:1px solid var(--rule);padding-top:8px;line-height:1.3}
    .card__meta h3{font-size:1.1rem}
    .card__meta .sub{color:var(--muted);font-weight:500}
    .card:hover .card__meta h3{color:var(--blue)}
    @media(max-width:900px){ .works-grid{columns:2} }
    @media(max-width:560px){ .works-grid{columns:1} }
  </style>

  <script>
    const state = { type: 'all', year: 'all' };
    const grid = document.getElementById('grid');
    const cards = [...grid.querySelectorAll('.card')];
    const empty = document.getElementById('empty');
    document.querySelectorAll('.fbtn').forEach(b => b.addEventListener('click', () => {
      const f = b.dataset.f; state[f] = b.dataset.v;
      document.querySelectorAll(`.fbtn[data-f="${f}"]`).forEach(x => x.classList.toggle('is-active', x === b));
      let vis = 0;
      cards.forEach(c => {
        const ok = (state.type === 'all' || c.dataset.type === state.type) &&
                   (state.year === 'all' || c.dataset.year === state.year);
        c.style.display = ok ? '' : 'none'; if (ok) vis++;
      });
      empty.style.display = vis ? 'none' : 'block';
    }));
  </script>
</Base>
