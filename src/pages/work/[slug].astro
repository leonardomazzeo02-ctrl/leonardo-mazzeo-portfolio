---
import Base from '../../layouts/Base.astro';
import { works } from '../../data/works.js';

export function getStaticPaths() {
  return works.map((w, i) => ({
    params: { slug: w.slug },
    props: { w, next: works[(i + 1) % works.length] }
  }));
}
const { w, next } = Astro.props;
const blocks = [
  ['Overview', w.overview],
  ['Ruolo', w.role],
  ['Sfida', w.challenge],
  ['Processo', w.process],
  ['Soluzione', w.solution],
];
---
<Base title={`${w.title} · Leonardo Mazzeo`} description={w.overview}>
  <!-- HERO progetto -->
  <section class="wrap" style="padding-top:18vh">
    <p class="kicker" data-reveal>{w.category} · {w.year}</p>
    <h1 data-reveal style="margin-top:.2em">{w.title}</h1>
    <p class="lead" data-reveal style="margin-top:.4em;color:var(--muted)">{w.subtitle}</p>
  </section>

  <!-- cover full-bleed -->
  <div class="cover" data-reveal style={`--accent:${w.accent}`}>
    {w.cover ? <img src={w.cover} alt={w.title} /> : <span>{w.title}</span>}
  </div>

  <!-- contenuti -->
  <section class="wrap grid" style="row-gap:clamp(28px,4vw,56px)">
    {blocks.map(([label, text]) => (
      <div class="block" data-reveal>
        <div class="block__label"><span class="kicker">{label}</span></div>
        <p class="body">{text}</p>
      </div>
    ))}
  </section>

  <!-- immagini extra -->
  {w.images.length > 1 && (
    <section class="wrap" style="padding-top:0">
      {w.images.map(src => <img class="shot" data-reveal src={src} alt={w.title} loading="lazy" />)}
    </section>
  )}

  <!-- next -->
  <a class="next wrap" href={`/work/${next.slug}`} data-reveal>
    <span class="kicker">Progetto successivo</span>
    <h2>{next.title} →</h2>
  </a>

  <style>
    .cover{margin:clamp(28px,5vw,64px) 0;height:clamp(360px,72vh,720px);background:var(--accent);
      display:grid;place-items:center;overflow:hidden}
    .cover img{max-width:100%;max-height:100%;width:auto;height:auto;object-fit:contain}
    .cover span{color:#fff;font-weight:900;font-size:clamp(2rem,8vw,6rem);letter-spacing:-.03em}
    .block{grid-column:span 6;display:grid;grid-template-columns:1fr;gap:10px}
    .block__label{border-top:1.5px solid var(--ink);padding-top:8px}
    .shot{display:block;max-width:100%;max-height:82vh;width:auto;height:auto;margin:0 auto var(--gap);border-radius:10px}
    .next{display:block;border-top:2px solid var(--ink);padding-top:20px;margin-top:40px}
    .next:hover h2{color:var(--blue)}
    @media(max-width:720px){ .block{grid-column:1 / -1} }
  </style>
</Base>
